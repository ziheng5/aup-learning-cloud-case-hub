{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "required": ["kind", "tool", "args"],
      "properties": {
        "kind": { "const": "tool" },
        "tool": {
          "enum": ["search_code", "open_file", "run_task", "git_apply_check", "write_files"]
        },
        "args": { "type": "object" }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["kind", "format", "content"],
      "properties": {
        "kind": { "const": "final" },
        "format": { "enum": ["markdown", "json"] },
        "content": { "type": "string" }
      },
      "additionalProperties": false
    }
  ]
}

