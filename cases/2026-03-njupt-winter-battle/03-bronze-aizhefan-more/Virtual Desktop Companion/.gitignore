# ============================================
# Node.js 项目忽略规则（客户端）
# ============================================

# 依赖目录 - 绝对不能上传
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# 运行时生成的日志文件
logs
*.log

# 运行时数据
pids
*.pid
*.seed
*.pid.lock

# 测试覆盖率报告
coverage/
.nyc_output/

# 构建输出目录
dist/
build/
out/

# Electron 构建输出
release/
*.exe
*.dmg
*.AppImage
*.deb
*.rpm
*.snap
*.msi

# ============================================
# Python 项目忽略规则（服务端）
# ============================================

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 虚拟环境
venv/
env/
ENV/
.venv

# Python 打包和分发
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.manifest
*.spec

