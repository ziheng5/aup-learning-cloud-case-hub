{
  "name": "ai-desktop-pet-client",
  "version": "1.0.0",
  "description": "AI Desktop Pet Client with Live2D",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win"
  },
  "keywords": [
    "electron",
    "vue",
    "live2d",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "express": "^5.2.1"
  },
  "build": {
    "appId": "com.aidesktoppet.app",
    "productName": "AIDesktopPet",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "portable": {
      "unicode": false,
      "artifactName": "${productName}_Portable.exe"
    }
  },
  "type": "commonjs"
}
